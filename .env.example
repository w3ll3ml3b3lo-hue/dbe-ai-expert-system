# DBE AI Expert System Environment Configuration

# ============================================================================
# Azure Credentials (Required for Real Integration)
# ============================================================================

# Azure Subscription & Authentication
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ============================================================================
# Cosmos DB Configuration (Knowledge Ingestion)
# ============================================================================

COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key-here
COSMOS_DATABASE_NAME=KnowledgeDB
COSMOS_CONTAINER_NAME=IntelligenceStore

# Cosmos DB Gremlin (Knowledge Graph)
COSMOS_GREMLIN_ENDPOINT=https://your-cosmos-account.gremlin.cosmos.azure.com:443/
COSMOS_GREMLIN_KEY=your-gremlin-key-here

# ============================================================================
# Azure Storage Configuration (Feedback & Data)
# ============================================================================

AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...AccountKey=...
AZURE_STORAGE_CONTAINER_FEEDBACK=feedback
AZURE_STORAGE_CONTAINER_DOCUMENTS=documents

# ============================================================================
# Azure Machine Learning Configuration
# ============================================================================

AZURE_ML_ENDPOINT=https://your-aml-endpoint.eastus.inference.ml.azure.com/score
AZURE_ML_KEY=your-aml-key-here
AZURE_ML_WORKSPACE=your-ml-workspace-name
AZURE_RESOURCE_GROUP=your-resource-group-name

# ============================================================================
# FastAPI & Orchestration Service
# ============================================================================

PORT=8000
ENVIRONMENT=development  # Options: development, staging, production
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# API Gateway Configuration
# ============================================================================

API_MANAGEMENT_ENDPOINT=https://your-apim.management.azure.com/
API_MANAGEMENT_KEY=your-apim-key-here
API_CLIENT_ID=your-api-client-id
API_ALLOWED_ORIGINS=https://localhost:3000,https://your-web-app.gov.za

# ============================================================================
# Monitoring & Observability
# ============================================================================

APPLICATION_INSIGHTS_KEY=your-appinsights-instrumentation-key
AZURE_MONITOR_WORKSPACE=your-monitor-workspace-name

# ============================================================================
# Security & Secrets
# ============================================================================

KEY_VAULT_NAME=your-key-vault-name
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Development & Testing
# ============================================================================

DEBUG=false
TEST_MODE=false  # Set to true for integration testing with mocks
PYTEST_MARKERS=integration  # pytest markers to run

# ============================================================================
# Advanced Configuration (Optional)
# ============================================================================

# Feedback Loop & Retraining
FEEDBACK_RETRAINING_THRESHOLD=10  # Trigger retraining after N low-rated feedbacks
FEEDBACK_STORAGE_RETENTION_DAYS=90

# Performance Tuning
COSMOS_THROUGHPUT=400  # RU/s for container
CONNECTION_POOL_SIZE=10
CACHE_TTL_SECONDS=3600

# ============================================================================
# Notes for Each Section
# ============================================================================

# Azure Credentials:
#   - Use Azure CLI: `az account show --query id -o tsv`
#   - Service Principal credentials from Azure AD App Registration
#   - Never commit real secrets; use Key Vault for production

# Cosmos DB:
#   - Create resources in Azure Portal or via Terraform
#   - Endpoint and keys found in Cosmos account "Keys" section
#   - Gremlin endpoint is typically: <cosmos-account>.gremlin.cosmos.azure.com

# Azure Storage:
#   - Connection string format: DefaultEndpointsProtocol=https;...
#   - Found in Storage Account "Access keys" section

# Azure ML:
#   - Endpoint and key from ML workspace "Endpoints" section
#   - Used for expert model inference

# FastAPI:
#   - PORT: defaults to 8000 if not set
#   - ENVIRONMENT: affects logging and configuration defaults
#   - LOG_LEVEL: controls verbosity of application logs

# Security:
#   - JWT_SECRET_KEY: should be a strong, randomly generated string
#   - Store all secrets in Azure Key Vault in production
#   - Never commit .env file to version control

# Testing:
#   - TEST_MODE=true: enables mocked Azure service calls
#   - Useful for local development without Azure credentials
#   - Set to false for integration testing with real services
